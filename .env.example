# Example environment variables for SEEK with OIDC (copy to .env and edit values)
# All variables are read by docker-compose.yml and forwarded into the container.

# ---------------------------------------------------------------------------
# OmniAuth / OIDC – core settings
# ---------------------------------------------------------------------------
OMNIAUTH_ENABLED=true
OMNIAUTH_OIDC_ENABLED=true

# Display name shown on the login button
OMNIAUTH_OIDC_NAME=SRAM

# OIDC provider discovery URL (issuer)
OMNIAUTH_OIDC_ISSUER=https://your-provider.example/realms/your-realm

# Client credentials registered with your OIDC provider
OMNIAUTH_OIDC_CLIENT_ID=your-client-id
OMNIAUTH_OIDC_SECRET=your-client-secret

# Redirect URI — must match the one registered with your OIDC provider
OMNIAUTH_OIDC_REDIRECT_URI=http://localhost:3000/auth/oidc/callback

# Space-separated scopes requested from the OIDC provider.
# Add any custom scope needed to expose group/role claims (e.g. entitlement, groups).
OMNIAUTH_OIDC_SCOPE=openid email profile entitlement

# ---------------------------------------------------------------------------
# Group/role → Project mapping
# ---------------------------------------------------------------------------
# Dot-notation is supported for nested claims, e.g.:
#   realm_access.roles         → Keycloak realm roles (default)
#   resource_access.myapp.roles → Keycloak client roles
#   groups                     → plain "groups" claim
#   entitlement                → SRAM / ELIXIR AAI entitlements
OMNIAUTH_OIDC_GROUPS=entitlement

# Comma/space/semicolon-separated keywords: if a group value contains one of
# these (case-insensitive), the user is added as Project Administrator instead
# of a regular member. Code default: admin,administrator,owner,admins,owners
OMNIAUTH_OIDC_ADMIN_KEYWORDS=admin,administrator,owner,admins,owners

# ---------------------------------------------------------------------------
# Default Institution (created at startup, used for all OIDC memberships)
# Country must be a valid ISO 3166-1 alpha-2 code (e.g. NL, GB, DE, US).
# ---------------------------------------------------------------------------
OMNIAUTH_OIDC_DEFAULT_INSTITUTION=Default Institution
OMNIAUTH_OIDC_DEFAULT_INSTITUTION_COUNTRY=NL
OMNIAUTH_OIDC_DEFAULT_INSTITUTION_CITY=Duckstad
OMNIAUTH_OIDC_DEFAULT_INSTITUTION_WEB=http://www.example.com
